
@page
@model RoomBoard.Web.Pages.Admin.DailyPrintModel
@{
    ViewData["Title"] = "Ημερήσια εκτύπωση";
    var periodCount = Math.Max(Model.Periods.Count, 1);
}

<section class="timeline-header weekly-screen-controls no-print">
    <div>
        <p class="eyebrow">Εκτύπωση</p>
        <h1>Ημερήσιο πρόγραμμα κρατήσεων</h1>
        <p class="muted">Timeline εκτύπωση ανά αίθουσα και διδακτική ώρα.</p>
    </div>

    <div class="timeline-header-actions">
        <form method="get" class="date-jump-form">
            <label>
                Ημερομηνία
                <input asp-for="Date" type="date" />
            </label>
            <button type="submit">Προβολή</button>
        </form>

        <a class="secondary-button" asp-page="/Admin/Prints">← Εκτυπώσεις</a>
        <button type="button" class="primary-button" onclick="window.print()">Εκτύπωση ημέρας</button>
    </div>
</section>

<section class="roomboard-print-sheet">
    <header class="roomboard-print-header">
        <div class="print-school-block">
            @if (!string.IsNullOrWhiteSpace(Model.SchoolSettings.LogoPath))
            {
                <img src="@Model.SchoolSettings.LogoPath" alt="Λογότυπο σχολικής μονάδας" />
            }
            <div>
                <p>@Model.SchoolSettings.SchoolType</p>
                <h1>@Model.SchoolSettings.SchoolName</h1>
                <span>@Model.SchoolSettings.SchoolYear</span>
                @if (!string.IsNullOrWhiteSpace(Model.SchoolSettings.Address) ||
                     !string.IsNullOrWhiteSpace(Model.SchoolSettings.Phone) ||
                     !string.IsNullOrWhiteSpace(Model.SchoolSettings.Email))
                {
                    <small>
                        @Model.SchoolSettings.Address
                        @if (!string.IsNullOrWhiteSpace(Model.SchoolSettings.Phone))
                        {
                            <text> · Τηλ. @Model.SchoolSettings.Phone</text>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.SchoolSettings.Email))
                        {
                            <text> · @Model.SchoolSettings.Email</text>
                        }
                    </small>
                }
            </div>
        </div>

        <div class="print-report-block">
            <strong>Ημερήσια εκτύπωση</strong>
            <span>@Model.Date.ToString("dddd, dd MMMM yyyy")</span>
            <small>Εκτύπωση: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
    </header>

    <section class="print-timeline-board" style="--period-count:@periodCount">
        <div class="print-timeline-grid">
            <div class="print-timeline-corner">Αίθουσα</div>

            @foreach (var period in Model.Periods)
            {
                <div class="print-period-head">
                    <strong>@period.Label</strong>
                    <span>@period.StartTime.ToString("HH:mm") - @period.EndTime.ToString("HH:mm")</span>
                </div>
            }

            @foreach (var room in Model.Rooms)
            {
                var bookings = Model.Bookings
                    .Where(b => b.Room.Id == room.Id)
                    .OrderBy(b => b.StartPeriod.Number)
                    .ToList();

                <div class="print-room-label">
                    <strong>@room.Name</strong>
                    <span>@room.Location</span>
                </div>

                <div class="print-timeline-lane">
                    @foreach (var period in Model.Periods)
                    {
                        var isBusy = bookings.Any(b => b.CoversPeriodNumber(period.Number));
                        <span class="print-lane-slot @(isBusy ? "taken" : "open")"></span>
                    }

                    @foreach (var booking in bookings)
                    {
                        var startIndex = Model.Periods.ToList().FindIndex(p => p.Id == booking.StartPeriod.Id);
                        var endIndex = Model.Periods.ToList().FindIndex(p => p.Id == booking.EndPeriod.Id);

                        if (startIndex >= 0 && endIndex >= startIndex)
                        {
                            var span = endIndex - startIndex + 1;
                            <article class="print-booking-block" style="--start:@(startIndex + 1); --span:@span">
                                <strong>@(booking.ClassGroup?.Name ?? "-") · @booking.SubjectOrPurpose</strong>
                                <span>@booking.Teacher.FullName</span>
                                <small>@booking.PeriodRangeLabel</small>
                            </article>
                        }
                    }
                </div>
            }
        </div>
    </section>

    <footer class="roomboard-print-footer">
        <div>
            <img src="~/img/app/roomboard-app-icon.svg" alt="RoomBoard" />
            <span>RoomBoard</span>
        </div>
        <span>Οι κενές θέσεις είναι διαθέσιμες για κράτηση.</span>
    </footer>
</section>
