
@page
@model RoomBoard.Web.Pages.Admin.WeeklyPrintModel
@{
    ViewData["Title"] = "Εβδομαδιαία εκτύπωση";
    var periodCount = Math.Max(Model.Periods.Count, 1);
    var selectedExtraRoomIds = Model.ExtraRoomIds?.Distinct().ToHashSet() ?? new HashSet<int>();
    var activeDays = Model.WeekDays
        .Where(day => Model.BookingsByDate.TryGetValue(day, out var bookings) && (bookings.Any() || selectedExtraRoomIds.Any()))
        .ToList();
    var totalBookings = activeDays.Sum(day => Model.BookingsByDate.TryGetValue(day, out var bookings) ? bookings.Count : 0);
}

<section class="timeline-header weekly-screen-controls no-print">
    <div>
        <p class="eyebrow">Εκτύπωση</p>
        <h1>Εβδομαδιαίο πρόγραμμα αλλαγών</h1>
        <p class="muted">Οι αίθουσες με κράτηση εκτυπώνονται πάντα. Μπορείτε να προσθέσετε και έξτρα άδειες αίθουσες.</p>
    </div>

    <div class="timeline-header-actions">
        <form method="get" class="date-jump-form print-options-form">
            <label>
                Εβδομάδα
                <input asp-for="WeekStart" type="date" />
            </label>

            <details class="extra-print-rooms">
                <summary>+ Έξτρα αίθουσες</summary>
                <div>
                    @foreach (var room in Model.Rooms)
                    {
                        <label>
                            <input type="checkbox" name="ExtraRoomIds" value="@room.Id" checked="@selectedExtraRoomIds.Contains(room.Id)" />
                            <span>@room.Name</span>
                        </label>
                    }
                </div>
            </details>

            <button type="submit">Προβολή</button>
        </form>

        <a class="secondary-button" asp-page="/Admin/Prints">← Εκτυπώσεις</a>
        <a class="secondary-button" asp-page="/Admin/DailyPrint" asp-route-Date="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")">Ημερήσια</a>
        <button type="button" class="primary-button" onclick="window.print()">Εκτύπωση εβδομάδας</button>
    </div>
</section>

<section class="roomboard-print-sheet weekly-timeline-print-sheet compact-changes-print-sheet">
    <header class="roomboard-print-header">
        <div class="print-school-block">
            @if (!string.IsNullOrWhiteSpace(Model.SchoolSettings.LogoPath))
            {
                <img src="@Model.SchoolSettings.LogoPath" alt="Λογότυπο σχολικής μονάδας" />
            }
            <div>
                <p>@Model.SchoolSettings.SchoolType</p>
                <h1>@Model.SchoolSettings.SchoolName</h1>
                <span>@Model.SchoolSettings.SchoolYear</span>
                @if (!string.IsNullOrWhiteSpace(Model.SchoolSettings.Address) ||
                     !string.IsNullOrWhiteSpace(Model.SchoolSettings.Phone) ||
                     !string.IsNullOrWhiteSpace(Model.SchoolSettings.Email))
                {
                    <small>
                        @Model.SchoolSettings.Address
                        @if (!string.IsNullOrWhiteSpace(Model.SchoolSettings.Phone))
                        {
                            <text> · Τηλ. @Model.SchoolSettings.Phone</text>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.SchoolSettings.Email))
                        {
                            <text> · @Model.SchoolSettings.Email</text>
                        }
                    </small>
                }
            </div>
        </div>

        <div class="print-report-block">
            <strong>Εβδομαδιαία εκτύπωση αλλαγών</strong>
            <span>@Model.WeekRangeText</span>
            <small>@totalBookings κρατήσεις · @activeDays.Count ημέρες εκτύπωσης</small>
            <small>Εκτύπωση: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
    </header>

    @if (activeDays.Count == 0)
    {
        <section class="print-empty-state">
            <strong>Δεν υπάρχουν κρατήσεις/αλλαγές για την εβδομάδα.</strong>
            <span>Επιλέξτε έξτρα αίθουσες από τις επιλογές εκτύπωσης αν θέλετε να εμφανιστούν άδειες γραμμές.</span>
        </section>
    }
    else
    {
        @foreach (var day in activeDays)
        {
            var dayBookings = Model.BookingsByDate.TryGetValue(day, out var foundBookings)
                ? foundBookings
                : Array.Empty<RoomBoard.Web.Models.BookingDetails>();

            var bookedRoomIds = dayBookings.Select(booking => booking.Room.Id).Distinct().ToHashSet();
            var printRooms = Model.Rooms
                .Where(room => bookedRoomIds.Contains(room.Id) || selectedExtraRoomIds.Contains(room.Id))
                .ToList();

            <section class="print-day-section">
                <header class="print-day-header">
                    <h2>@day.ToString("dddd, dd MMMM yyyy")</h2>
                    <span>@dayBookings.Count κρατήσεις · @printRooms.Count αίθουσες</span>
                </header>

                <section class="print-timeline-board" style="--period-count:@periodCount">
                    <div class="print-timeline-grid print-filtered-rooms-grid">
                        <div class="print-timeline-corner">Αίθουσα</div>

                        @foreach (var period in Model.Periods)
                        {
                            <div class="print-period-head">
                                <strong>@period.Label</strong>
                                <span>@period.StartTime.ToString("HH:mm") - @period.EndTime.ToString("HH:mm")</span>
                            </div>
                        }

                        @foreach (var room in printRooms)
                        {
                            var roomBookings = dayBookings
                                .Where(b => b.Room.Id == room.Id)
                                .OrderBy(b => b.StartPeriod.Number)
                                .ToList();

                            <div class="print-room-label @(roomBookings.Count == 0 ? "extra-room-label" : "")">
                                <strong>@room.Name</strong>
                                <span>@room.Location</span>
                                @if (roomBookings.Count == 0)
                                {
                                    <small>έξτρα</small>
                                }
                            </div>

                            <div class="print-timeline-lane">
                                @foreach (var period in Model.Periods)
                                {
                                    var isBusy = roomBookings.Any(b => b.CoversPeriodNumber(period.Number));
                                    <span class="print-lane-slot @(isBusy ? "taken" : "open")"></span>
                                }

                                @foreach (var booking in roomBookings)
                                {
                                    var startIndex = Model.Periods.ToList().FindIndex(p => p.Id == booking.StartPeriod.Id);
                                    var endIndex = Model.Periods.ToList().FindIndex(p => p.Id == booking.EndPeriod.Id);

                                    if (startIndex >= 0 && endIndex >= startIndex)
                                    {
                                        var span = endIndex - startIndex + 1;
                                        <article class="print-booking-block" style="--start:@(startIndex + 1); --span:@span">
                                            <strong>@(booking.ClassGroup?.Name ?? "-") · @booking.SubjectOrPurpose</strong>
                                            <span>@booking.Teacher.FullName</span>
                                            <small>@booking.PeriodRangeLabel</small>
                                        </article>
                                    }
                                }
                            </div>
                        }
                    </div>
                </section>
            </section>
        }
    }

    <footer class="roomboard-print-footer">
        <div>
            <img src="~/img/app/roomboard-app-icon.svg" alt="RoomBoard" />
            <span>RoomBoard</span>
        </div>
        <span>Αίθουσες με κρατήσεις + προαιρετικά επιλεγμένες έξτρα αίθουσες.</span>
    </footer>
</section>
